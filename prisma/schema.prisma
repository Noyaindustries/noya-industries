generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Service {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  slug        String   @unique
  title       String
  subtitle    String?
  description String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Stat {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  label     String
  value     String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String
  company   String?
  phone     String?
  topic     String?
  message   String
  createdAt DateTime @default(now())
}

model BlogPost {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  slug      String   @unique
  category  String
  title     String
  excerpt   String
  imageUrl  String?
  dateLabel String
  readTime  String
  featured  Boolean  @default(false)
  content   String[]
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeamMember {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  slug      String   @unique
  initials  String
  name      String
  role      String
  tone      String
  desc      String
  skills    String[]
  imageUrl  String?
  linkedin  String?
  facebook  String?
  instagram String?
  tiktok    String?
  x         String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
