generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Service {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  slug        String   @unique
  title       String
  subtitle    String?
  description String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Stat {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  label     String
  value     String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String
  company   String?
  phone     String?
  topic     String?
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CrmClient {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  slug        String   @unique
  name        String
  sector      String
  pole        String
  value       Int
  contactDate String
  status      String
  initials    String
  avBg        String
  avColor     String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CrmActivity {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  title      String
  clientName String
  type       String
  dateLabel  String
  status     String
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model MissionProject {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  slug           String   @unique
  name           String
  client         String
  ownerInitials  String
  ownerBg        String
  ownerColor     String?
  deadline       String
  deadlineWarn   Boolean  @default(false)
  progress       Int
  barColor       String
  status         String
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model FinanceInvoice {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  number     String   @unique
  client     String
  mission    String
  dateLabel  String
  dueLabel   String
  amount     Int
  amountTone String   @default("gold")
  status     String
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model StockItem {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  ref         String   @unique
  label       String
  category    String
  quantity    Int
  price       Int
  minQuantity Int      @default(5)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AcademyProgram {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  slug        String   @unique
  name        String
  type        String
  learners    Int
  progress    Int
  nextSession String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LeaveRequest {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  employeeName  String
  periodLabel   String
  durationLabel String
  reason        String
  status        String
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CommsTemplate {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  slug      String   @unique
  name      String
  channel   String
  subject   String
  body      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlogPost {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  slug      String   @unique
  category  String
  title     String
  excerpt   String
  imageUrl  String?
  dateLabel String
  readTime  String
  featured  Boolean  @default(false)
  content   String[]
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeamMember {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  slug      String   @unique
  initials  String
  name      String
  role      String
  tone      String
  desc      String
  skills    String[]
  imageUrl  String?
  linkedin  String?
  facebook  String?
  instagram String?
  tiktok    String?
  x         String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlogComment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  postSlug  String
  author    String
  message   String
  createdAt DateTime @default(now())
}

model AdminUser {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  email             String    @unique
  name              String
  passwordHash      String
  passwordChangedAt DateTime?
  lastLoginAt       DateTime?
  lastLoginIp       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model AppSettings {
  id                         String   @id @default("default") @map("_id")
  companyName                String
  legalName                  String
  contactEmail               String
  phone                      String
  phoneSecondary             String?
  website                    String
  city                       String
  address                    String
  twoFactorEnabled           Boolean  @default(false)
  loginAlerts                Boolean  @default(true)
  sessionTimeoutEnabled      Boolean  @default(true)
  passwordRotationDays       Int      @default(90)
  infinitecoreWebhookUrl     String?
  infinitecoreWebhookEnabled Boolean  @default(true)
  recruitmentPublicUrl       String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}
